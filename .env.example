# MiniCookingAgent-Demo — 迷你烹饪问答机器人配置

# 推荐默认：本地模型工具循环
AGENT_ADAPTER=agent_adapter_local_LLM_harness

# DeepSeek 配置（仅 agent_adapter 需要）
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI 兼容本地模型配置（LM Studio / vLLM / Ollama OpenAI API）
LLM_MODEL=qwen3-4b
LLM_BASE_URL=http://127.0.0.1:51234/v1
LLM_API_KEY=not-needed
LLM_MAX_TOKENS=2048
LLM_NO_THINK=1
INTENT_ROUTER_NO_THINK=1
QUERY_PLAN_NO_THINK=1
FINAL_ANSWER_NO_THINK=1
MAX_MODEL_LEN=32768
MAX_TOOL_TURNS=5
MAX_TOTAL_TOOL_CALLS=5
MAX_CONSECUTIVE_TOOL_CALLS=3

# 远端 LM Studio 只监听 127.0.0.1:1234 时，可启用 SSH 本地转发。
LLM_SSH_TUNNEL=0
LLM_REMOTE_HOST=your.server.com
LLM_REMOTE_USER=ubuntu
LLM_REMOTE_PASSWORD=your_password
LLM_REMOTE_PORT=1234
LLM_LOCAL_PORT=51234

# 服务端口
HOST=0.0.0.0
PORT=8000
FRONTEND_PORT=5173
